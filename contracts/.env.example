# Optional existing infra
# Arbitrum Sepolia: strongly recommended to fill the standard deployed EntryPoint.
# Leave empty only for local/anvil deployments where you explicitly want to deploy a fresh EntryPoint.
ENTRY_POINT_ADDRESS=0x0000000071727de22e5e9d8baf0edac6f37da032

# Leave empty to deploy MockUSDC as the billing token.
# Fill this only if you already have a billing ERC20 deployed on the target network.
BILLING_TOKEN_ADDRESS=

# Billing config
# Billing-token quote per 1 native token of gas cost, expressed with 1e18 precision.
TOKEN_PER_NATIVE_TOKEN=3000000000

# Paymaster markup in basis points. 500 = 5%.
MARKUP_BPS=500

# Optional paymaster setup
# Native-asset deposit/stake sent into EntryPoint for this paymaster.
INITIAL_PAYMASTER_DEPOSIT=0
INITIAL_PAYMASTER_STAKE=0
PAYMASTER_UNSTAKE_DELAY=86400

# Optional paymaster ownership handoff.
# ArbAgentPaymaster uses Ownable2Step, so this becomes pendingOwner until acceptOwnership() is called.
# Leave empty if the deployer wallet should remain the active paymaster owner immediately after deployment.
PAYMASTER_OWNER=

# Optional initial MockUSDC mint.
# Only used when BILLING_TOKEN_ADDRESS is empty and a new MockUSDC is deployed by the script.
MOCK_USDC_MINT_RECIPIENT=
INITIAL_MOCK_USDC_MINT=0