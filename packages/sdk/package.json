      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "permissionless": "^0.3.5",
    "viem": "^2.50.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.8.2"
  }
}
